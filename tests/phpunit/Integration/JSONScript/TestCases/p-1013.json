{
	"description": "Test change-propagation: shallow update for category _SUBC diff and forced update for property _TYPE diff",
	"setup": [
		{
			"namespace": "NS_CATEGORY",
			"page": "P1013-Foo",
			"contents": ""
		},
		{
			"namespace": "NS_CATEGORY",
			"page": "P1013-Bar",
			"contents": ""
		},
		{
			"namespace": "NS_MAIN",
			"page": "P1013-Member",
			"contents": "[[Category:P1013-Foo]]"
		},
		{
			"namespace": "SMW_NS_PROPERTY",
			"page": "P1013-HasNumber",
			"contents": "[[Has type::Number]]"
		},
		{
			"namespace": "NS_MAIN",
			"page": "P1013-Subject",
			"contents": "[[P1013-HasNumber::42]]"
		},
		{
			"namespace": "NS_CATEGORY",
			"page": "P1013-Foo",
			"contents": "[[Category:P1013-Bar]]"
		}
	],
	"beforeTest": {
		"job-run": [
			"smw.update",
			"smw.changePropagationDispatch",
			"smw.changePropagationClassUpdate",
			"smw.changePropagationUpdate"
		]
	},
	"tests": [
		{
			"type": "parser",
			"about": "#0 category member has _SUBC stored after _SUBC propagation (shallow update path)",
			"namespace": "NS_CATEGORY",
			"subject": "P1013-Foo",
			"store": {
				"clear-cache": true
			},
			"assert-store": {
				"semantic-data": {
					"strictPropertyValueMatch": false,
					"propertyCount": 3,
					"propertyKeys": [
						"_SUBC",
						"_MDAT",
						"_SKEY"
					]
				}
			}
		},
		{
			"type": "parser",
			"about": "#1 subject retains typed property value after propagation pipeline (forced update path)",
			"namespace": "NS_MAIN",
			"subject": "P1013-Subject",
			"store": {
				"clear-cache": true
			},
			"assert-store": {
				"semantic-data": {
					"strictPropertyValueMatch": false,
					"propertyKeys": [
						"P1013-HasNumber",
						"_MDAT",
						"_SKEY"
					]
				}
			}
		}
	],
	"settings": {
		"wgContLang": "en",
		"wgLang": "en",
		"smwgPageSpecialProperties": [
			"_MDAT"
		],
		"smwgQSubcategoryDepth": 10,
		"smwgNamespacesWithSemanticLinks": {
			"NS_MAIN": true,
			"SMW_NS_PROPERTY": true,
			"NS_CATEGORY": true
		}
	},
	"meta": {
		"version": "2",
		"is-incomplete": false,
		"debug": false
	}
}
