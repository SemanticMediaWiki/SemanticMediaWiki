{{!
  EntityExaminer indicator compare list (two key/value rows).

  Required data:
  - explain: string (escaped) - Explanatory text
  - first_key: string (escaped) - First row key
  - first_value: string (escaped) - First row value
  - second_key: string (escaped) - Second row key
  - second_value: string (escaped) - Second row value
}}
<div class="smw-indicator-compare-list"><p>{{explain}}</p><div class="smw-indicator-compare-list-row"><span>{{first_key}}</span><span>{{first_value}}</span></div><div class="smw-indicator-compare-list-row"><span>{{second_key}}</span><span>{{second_value}}</span></div></div>
