{{!
  EntityExaminer composite placeholder (deferred-load loader element).

  Required data:
  - subject: string (escaped) - Subject page hash
  - dir: string (escaped) - Text direction
  - uselang: string (escaped) - Interface language code
  - title: string (escaped) - Title attribute text
}}
<div class="smw-entity-examiner smw-indicator-vertical-bar-loader" data-subject="{{subject}}" data-dir="{{dir}}" data-uselang="{{uselang}}" title="{{title}}"></div>
